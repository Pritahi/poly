# ========================================
# Poly - Environment Configuration
# ========================================

# ─── Database ───────────────────────────────────
# Option A: SQLite (local dev — default)
DATABASE_URL="file:./db/custom.db"

# Option B: PostgreSQL (Railway / Render / Vercel Postgres)
# DATABASE_URL="postgresql://user:password@host:5432/poly?schema=public"

# Option C: Supabase (PostgreSQL-compatible)
# 1. Go to https://supabase.com → New Project
# 2. Settings → Database → Connection string → URI
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"
# 
# Supabase setup:
# - Create project at https://supabase.com
# - Copy connection string from Settings → Database
# - Replace with your actual password
# - Run: cp prisma/schema.postgresql.prisma prisma/schema.prisma
# - Run: npx prisma db push

# ─── AI Engine ──────────────────────────────────
# ZAI_API_KEY=your-zai-api-key

# ─── App ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Poly SDK ──────────────────────────────────
# POLY_CLOUD_ENDPOINT=https://your-app.up.railway.app
# POLY_DISABLE=0
